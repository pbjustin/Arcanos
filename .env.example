# Arcanos backend environment template
# Copy to .env and fill real values.

# Required at backend startup (src/config/env.ts)
PORT=3000

# Core runtime
NODE_ENV=development
# HOST=127.0.0.1
# SERVER_URL=http://127.0.0.1:3000
# Base URL used by CLI/scripts before SERVER_URL/BACKEND_URL fallbacks.
# ARCANOS_BACKEND_URL=http://127.0.0.1:3000

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MAX_RETRIES=2
# Production/Railway fails fast without OPENAI_API_KEY unless this rollback flag is false.
# OPENAI_API_KEY_REQUIRED=true

# Custom GPT Action -> GPT ID bridge
# Shared secret accepted as `Authorization: Bearer ...` or `x-openai-action-secret`.
OPENAI_ACTION_SHARED_SECRET=replace-with-a-strong-shared-secret
DEFAULT_GPT_ID=arcanos-core
# Optional comma-separated GPT IDs that must be registered at startup.
# REQUIRED_GPT_IDS=arcanos-core,core
# Optional legacy/custom GPT ID alias for ARCANOS:GAMING.
# GPTID_ARCANOS_GAMING=arcanos-gaming
# Optional bounded wait for `query_and_wait` before falling back to `/jobs/{id}` polling.
# OPENAI_ACTION_BRIDGE_WAIT_TIMEOUT_MS=3500
# Optional wait for plain `query`; keep `0` for immediate async responses.
# OPENAI_ACTION_BRIDGE_QUERY_WAIT_TIMEOUT_MS=0
# OPENAI_ACTION_BRIDGE_POLL_INTERVAL_MS=250
# Rolling health window for bridge failure counters.
# OPENAI_ACTION_BRIDGE_FAILURE_COUNTER_WINDOW_MS=900000
# Background module dispatch timeout for GPT routes; clamped by the dispatcher.
# GPT_BACKGROUND_DISPATCH_TIMEOUT_MS=180000

# GPT Access Gateway (/gpt-access/*)
# Required in production. Accepted only as `Authorization: Bearer ...`.
# Set ARCANOS_GPT_ACCESS_TOKEN out of band; never commit or document a real value.
# ARCANOS_GPT_ACCESS_TOKEN=replace-with-a-strong-token
# Optional comma-separated scope restriction. Empty enables existing read/control defaults only;
# jobs.create, capabilities.read, and capabilities.run must be listed explicitly before they can enqueue, discover, or execute capability work.
# ARCANOS_GPT_ACCESS_SCOPES=runtime.read,workers.read,queue.read,jobs.create,jobs.result,logs.read_sanitized,db.explain_approved,mcp.approved_readonly,capabilities.read,capabilities.run,diagnostics.read

# Legacy ask-style route migration. Default is `gone`; set `compat` only while
# migrating old `/brain` callers to `/gpt/:gptId`.
# ASK_ROUTE_MODE=gone

# Production safety controls
ALLOW_MOCK_FALLBACK=false
BUDGET_DISABLED=false
WATCHDOG_LIMIT_MS=120000
SAFETY_BUFFER_MS=2000
TRINITY_BASE_SOFT_CAP_MS=60000
TRINITY_MULT_SIMPLE=1.0
TRINITY_MULT_COMPLEX=1.4
TRINITY_MULT_CRITICAL=1.8
# Route queued Trinity DAG node execution through the GPT Access gateway job path.
# Leave unset to enable automatically only when worker slots are greater than DAG_MAX_CONCURRENT_NODES.
# Set true only after provisioning nested queue capacity; unsafe forced routing fails clearly.
# Set false for local legacy bridge debugging.
# TRINITY_DAG_GPT_ACCESS_ENABLED=true
# DEBUG_WATCHDOG=false
# DEBUG_WATCHDOG_KEY=replace-me

# ================================
# Deployment & Runtime Overrides
# ================================

# Railway / Platform
# Railway environment identifier (set automatically on Railway)
# RAILWAY_ENVIRONMENT=production
# Explicit Railway runtime contract for the shared launcher.
# Leave this unset for local direct runtime so RUN_WORKERS remains authoritative.
# - Railway web service: ARCANOS_PROCESS_KIND=web
# - Railway worker service: ARCANOS_PROCESS_KIND=worker
# ARCANOS_PROCESS_KIND=web
# Worker DB bootstrap retry controls; max attempts 0 means retry indefinitely.
# JOB_WORKER_DB_BOOTSTRAP_RETRY_MS=5000
# JOB_WORKER_DB_BOOTSTRAP_MAX_RETRY_MS=30000
# JOB_WORKER_DB_BOOTSTRAP_MAX_ATTEMPTS=0

# Optional Railway management API token (only required for automation scripts/CI)
RAILWAY_API_TOKEN=
# Railway GraphQL API override
# RAILWAY_GRAPHQL_ENDPOINT=https://backboard.railway.app/graphql/v2
# RAILWAY_GRAPHQL_TIMEOUT_MS=15000

# Public GPT response bounds
# Default falls back to CLIENT_RESPONSE_MAX_BYTES or 32768 bytes when unset.
# Set lower in preview/test to exercise explicit partial-response shaping.
# GPT_PUBLIC_RESPONSE_MAX_BYTES=8000
# Enables X-Debug-Max-Bytes for /gpt control responses outside production only.
# ARCANOS_ENABLE_DEBUG_GPT_CONTROLS=false

# Optional owner bootstrap (used only when identity modules are enabled).
# Use a verified email that should automatically receive owner/internal privileges.
ARCANOS_OWNER_EMAIL=you@example.com
# Optional comma-separated allowlist if you want more than one bootstrap owner email.
# ARCANOS_OWNER_EMAILS=you@example.com,alt@example.com

# Storage
# DATABASE_URL=postgresql://user:password@host:5432/database
# Optional private Railway-internal URL for in-platform services when DATABASE_URL is pointed at the public proxy.
# DATABASE_PRIVATE_URL=postgresql://user:password@postgres.railway.internal:5432/database?sslmode=no-verify
# Optional public proxy URL for local CLI/scripts when DATABASE_URL points at Railway private DNS.
# DATABASE_PUBLIC_URL=postgresql://user:password@public-proxy.rlwy.net:12345/database?sslmode=no-verify
# For local access to Railway Postgres, use the TCP proxy host/port and sslmode=no-verify.
# PGHOST=your-public-proxy.rlwy.net
# PGPORT=12345
# PGDATABASE=railway
# PGUSER=postgres
# PGPASSWORD=replace-me
# Redis can be configured with REDIS_URL or Railway-style discrete variables.
# REDIS_URL=redis://localhost:6379
# REDISHOST=
# REDISPORT=6379
# REDISUSER=
# REDISPASSWORD=
ARC_LOG_PATH=/tmp/arc/log
ARC_MEMORY_PATH=/tmp/arc/memory

# Workers
# Local direct-runtime toggle used when ARCANOS_PROCESS_KIND is unset or when bypassing the Railway launcher.
RUN_WORKERS=true
# OpenAI request timeout for worker API calls (ms)
WORKER_API_TIMEOUT_MS=60000
# Dedicated job-runner identity, concurrency, and polling controls.
# JOB_WORKER_ID=async-queue
# JOB_WORKER_STATS_ID=async-queue
# JOB_WORKER_CONCURRENCY=1
# DAG_MAX_CONCURRENT_NODES=1
# JOB_WORKER_POLL_MS=250
# JOB_WORKER_IDLE_BACKOFF_MS=1000
# Queue lifecycle and retry controls.
# JOB_WORKER_HEARTBEAT_MS=10000
# JOB_WORKER_LEASE_MS=30000
# JOB_WORKER_STALE_AFTER_MS=60000
# JOB_WORKER_INSPECTOR_MS=30000
# JOB_WORKER_WATCHDOG_MS=30000
# JOB_WORKER_WATCHDOG_IDLE_MS=120000
# JOB_WORKER_STALLED_JOB_ACTION=dead_letter
# JOB_WORKER_MAX_RETRIES=2
# JOB_WORKER_RETRY_BASE_MS=2000
# JOB_WORKER_RETRY_MAX_MS=60000
# Retained failed-job cleanup. Disable with QUEUE_FAILED_JOB_CLEANUP_ENABLED=false to roll back.
# QUEUE_FAILED_JOB_CLEANUP_ENABLED=true
# QUEUE_FAILED_JOB_RETENTION_COUNT=50
# QUEUE_FAILED_JOB_CLEANUP_MIN_AGE_MS=86400000
# Hybrid async ask-style behavior: wait briefly for a queued worker result before falling back to HTTP 202 polling.
# Set to `0` to preserve strict fire-and-poll behavior.
# ASK_ASYNC_WAIT_FOR_RESULT_MS=15000
# Optional poll interval while the API waits on a queued ask-style job.
# ASK_ASYNC_WAIT_POLL_MS=250
# Optional artifact store backend for DAG dependency payload offloading.
# Defaults to `database` on Railway and `filesystem` elsewhere when unset.
# TRINITY_ARTIFACT_STORE_BACKEND=database
# Optional shared artifact directory for filesystem-backed DAG artifacts.
# Ignored when the artifact backend is `database`.
# Defaults to $RAILWAY_VOLUME_MOUNT_PATH/trinity-artifacts on Railway when unset.
# TRINITY_ARTIFACT_STORE_DIR=/data/trinity-artifacts
# Predictive autoscaling thresholds for the main Trinity worker pool.
# AUTOSCALING_MAIN_CPU_THRESHOLD=0.8
# AUTOSCALING_MAIN_MEMORY_PRESSURE_THRESHOLD=0.8
# AUTOSCALING_MAIN_API_LATENCY_THRESHOLD_MS=300
# AUTOSCALING_DOMAIN_SURGE_MULTIPLIER=3

# Scholarly (CrossRef) API
# CROSSREF_API_URL=https://api.crossref.org/works
# CROSSREF_API_TIMEOUT_MS=15000
# CROSSREF_DEFAULT_ROWS=3

# Confirmation and automation
# Trusted GPT IDs (comma-separated) used by confirmation middleware and optional backend-service GPT-ID auth
# TRUSTED_GPT_IDS=
# Optional backend-service auth mode: api-key (default), gpt-id, hybrid
# AGENT_AUTH_MODE=api-key
# Optional backend-service specific GPT-ID allowlist override (falls back to TRUSTED_GPT_IDS)
# BACKEND_TRUSTED_GPT_IDS=
# ARCANOS_AUTOMATION_SECRET=
# ARCANOS_AUTOMATION_HEADER=x-arcanos-automation

# Optional model overrides
# FINETUNED_MODEL_ID=
# AI_MODEL=
# FALLBACK_MODEL=gpt-4
# GPT5_MODEL=gpt-5
# GPT51_MODEL=gpt-5.1
# HRC reviewer model override. Defaults to the normal OpenAI model selection.
# HRC_MODEL=

# GPT route fast path
# Enables inline execution for small prompt-generation requests on POST /gpt/:gptId.
GPT_FAST_PATH_ENABLED=true
# Optional inline model override. Defaults to the lightweight repo fast-path model.
# GPT_FAST_PATH_MODEL=gpt-4.1-mini
# GPT_FAST_PATH_TIMEOUT_MS=8000
# GPT_FAST_PATH_MAX_PROMPT_CHARS=900
# GPT_FAST_PATH_MAX_MESSAGE_COUNT=3
# GPT_FAST_PATH_MAX_WORDS=350
# Optional comma-separated GPT IDs allowed to use the fast path. Empty means all GPT IDs.
# GPT_FAST_PATH_GPT_ALLOWLIST=arcanos-core,core
# Optional legacy bridge for small unadorned core queries. Leave false so the bounded
# request-mode core path can return inline unless the request explicitly asks for async work.
# GPT_ROUTE_ASYNC_CORE_DEFAULT=false
# Priority GPT async execution and queue lane.
# PRIORITY_GPT_IDS=arcanos-core,arcanos-audit,arcanos-build,arcanos-research,arcanos-write,arcanos-guide,arcanos-sim,arcanos-tracker,arcanos-tutor,arcanos-daemon,core,audit,build,research,write,guide,sim,tracker,tutor
PRIORITY_QUEUE_ENABLED=true
PRIORITY_QUEUE_WEIGHT=5
GPT_DIRECT_EXECUTION_THRESHOLD_MS=8000
GPT_WAIT_TIMEOUT_MS=24000
GPT_JOB_MAX_RETRIES=1
# GPT_PRIORITY_DIRECT_EXECUTION_CONCURRENCY=1

# Gaming / Web Guide Fetch
# Default timeout budget for ARCANOS:GAMING module dispatch.
# ARCANOS_GAMING_MODULE_TIMEOUT_MS=60000
# Per-guide snippet size used by gaming guide URL enrichment.
# ARCANOS_GAMING_WEB_CONTEXT_CHARS=5000
# Shared SSRF-safe web fetch limits.
# WEB_FETCH_TIMEOUT_MS=8000
# WEB_FETCH_MAX_BYTES=1500000
# WEB_FETCH_MAX_CHARS=12000
# WEB_FETCH_MAX_LINKS=15
# Keep 0 unless audited; redirects can weaken host/IP pinning assumptions.
# WEB_FETCH_MAX_REDIRECTS=0
# WEB_FETCH_USER_AGENT=Arcanos-WebFetcher/1.0

# Feature flags
# ENABLE_ACTION_PLANS=false
# ENABLE_CLEAR_2=false
# Deprecated root/module AI routes. Leave enabled during migration to `/gpt/:gptId`,
# then set to `disabled` to remove `/arcanos`, `/write`, `/guide`, `/sim`,
# `/queryroute`, and `/modules/:moduleRoute`.
# LEGACY_GPT_ROUTES=enabled

# Self-heal loop
# Starts automatically on boot from src/server.ts and ticks every 30s by default.
# PREDICTIVE_HEALING_INTERVAL_MS=30000
# SELF_HEAL_LOOP_INTERVAL_MS=30000 # Alias for backward compatibility

# Predictive self-healing
# Keep dry-run on until you have audited decisions in /status/safety/self-heal and /api/self-heal/decide.
# PREDICTIVE_HEALING_ENABLED=false
# PREDICTIVE_HEALING_DRY_RUN=true
# PREDICTIVE_DRY_RUN=true # Alias for backward compatibility
# PREDICTIVE_AUTO_EXECUTE=false
# AUTO_EXECUTE_HEALING=false # Alias for backward compatibility
# PREDICTIVE_HEALING_WINDOW_MS=300000
# PREDICTIVE_HEALING_MIN_OBSERVATIONS=3
# PREDICTIVE_HEALING_STALE_AFTER_MS=120000
# Alias: PREDICTIVE_AUTO_EXECUTE_CONFIDENCE_THRESHOLD=0.65
# PREDICTIVE_HEALING_MIN_CONFIDENCE=0.65
# PREDICTIVE_HEALING_COOLDOWN_MS=300000
# Alias: PREDICTIVE_HEALING_ACTION_COOLDOWN_MS=300000
# AI diagnosis backoff keeps the provider path from firing every loop tick.
# Idle/default recommendation: 6h. Live incident recommendation: 30m.
# PREDICTIVE_HEALING_AI_IDLE_COOLDOWN_MS=21600000
# PREDICTIVE_HEALING_AI_ACTIVE_COOLDOWN_MS=1800000
# PREDICTIVE_HEALING_AI_FAILURE_COOLDOWN_MS=21600000
# PREDICTIVE_HEALING_OBSERVATION_HISTORY_LIMIT=12
# PREDICTIVE_HEALING_AUDIT_HISTORY_LIMIT=25
# PREDICTIVE_ERROR_RATE_THRESHOLD=0.18
# PREDICTIVE_LATENCY_CONSECUTIVE_INTERVALS=3
# PREDICTIVE_LATENCY_RISE_DELTA_MS=350
# PREDICTIVE_MEMORY_THRESHOLD_MB=1024
# PREDICTIVE_MEMORY_GROWTH_THRESHOLD_MB=192
# PREDICTIVE_MEMORY_SUSTAINED_INTERVALS=3
# PREDICTIVE_QUEUE_PENDING_THRESHOLD=5
# PREDICTIVE_QUEUE_VELOCITY_THRESHOLD=2
# PREDICTIVE_SCALE_UP_STEP=1
# PREDICTIVE_SCALE_UP_MAX_EXTRA_WORKERS=2

# Token safety limits
# TOKEN_SAFE_MAX=8000

# Safety hardening controls
SAFETY_HEARTBEAT_TIMEOUT_MS=15000
SAFETY_HEARTBEAT_MISS_THRESHOLD=3
SAFETY_HEALTHY_CYCLES_TO_RECOVER=3
SAFETY_QUARANTINE_COOLDOWN_MS=120000
SAFETY_WORKER_RESTART_THRESHOLD=5
SAFETY_WORKER_RESTART_WINDOW_MS=300000
DISPATCH_V9_POLICY_TIMEOUT_MS=5000
SAFETY_FAIL_CLOSED_INTEGRITY=true

# Optional integrity hash overrides (set to known-good sha256 values)
# SAFETY_EXPECTED_HASH_DISPATCH_PATTERNS=
# SAFETY_EXPECTED_HASH_PROMPTS=
# SAFETY_EXPECTED_HASH_FALLBACK_MESSAGES=
# SAFETY_EXPECTED_HASH_GPT_ROUTER_CONFIG=
# SAFETY_EXPECTED_HASH_ASSISTANT_REGISTRY=
# SAFETY_EXPECTED_HASH_DAEMON_TOKENS=
# SAFETY_EXPECTED_HASH_PROTECTED_JSON=

# OpenAI server-side storage of requests/responses (default false)
OPENAI_STORE=false

# MCP HTTP transport. Required before POST /mcp will accept requests.
# MCP_BEARER_TOKEN=replace-with-a-strong-token
# MCP_ALLOWED_ORIGINS=
# MCP_HTTP_BODY_LIMIT=1mb
# MCP_REQUIRE_CONFIRMATION=true
# MCP_CONFIRM_TTL_MS=60000
# MCP_EXPOSE_DESTRUCTIVE=false
# MCP_ENABLE_SESSIONS=false
# Also gates /gpt-access/capabilities/v1/:id/run; use final colon as module/action separator.
# Capability runs additionally require the GPT Access confirmation gate.
# MCP_ALLOW_MODULE_ACTIONS=ARCANOS:CORE:query

# Daemon tool continuation polling
DAEMON_RESULT_WAIT_MS=8000
DAEMON_RESULT_POLL_MS=250

# Admin observability
ADMIN_DB_PREVIEW_MAX_ROWS=100
ADMIN_DB_TABLE_LIST_LIMIT=40
# /metrics is enabled by default. Set token to require Authorization: Bearer
# or x-metrics-token; set METRICS_ENABLED=false to hide the endpoint.
# METRICS_AUTH_TOKEN=
# METRICS_ENABLED=true

# Web search agent
WEB_SEARCH_PROVIDER=auto
WEB_SEARCH_TIMEOUT_MS=10000
WEB_SEARCH_RATE_LIMIT_MAX=30
WEB_SEARCH_RATE_LIMIT_WINDOW_MS=600000
WEB_SEARCH_SNAPSHOT_CHARS=2000
TRAVERSE_LINKS_DEFAULT=false
WEB_SEARCH_TRAVERSAL_DEPTH=1
WEB_SEARCH_MAX_TRAVERSAL_PAGES=2
WEB_SEARCH_SAME_DOMAIN_ONLY=true
WEB_SEARCH_TRAVERSAL_LINK_LIMIT=3
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=
SERPAPI_API_KEY=
SEARXNG_BASE_URL=
