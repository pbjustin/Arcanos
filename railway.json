{
  "$schema": "https://railway.app/railway.schema.json",
  "name": "arcanos-backend",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm ci --include=dev --no-audit --no-fund && npm run build",
    "cache": {
      "npm": false
    },
    "env": {
      "NODE_ENV": "production",
      "NODE_OPTIONS": "--max_old_space_size=2048"
    }
  },
  "deploy": {
    "startCommand": "node scripts/start-railway-service.mjs",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "env": {
      "NODE_ENV": "production",
      "PORT": "$PORT",
      "ARCANOS_PROCESS_KIND": "$ARCANOS_PROCESS_KIND"
    }
  },
  "environments": {
    "production": {
      "variables": {
        "NODE_ENV": "production",
        "PORT": "$PORT",
        "DATABASE_URL": "$DATABASE_URL",
        "OPENAI_API_KEY": "$OPENAI_API_KEY",
        "OPENAI_API_KEY_REQUIRED": "true",
        "OPENAI_ACTION_SHARED_SECRET": "$OPENAI_ACTION_SHARED_SECRET",
        "ARCANOS_GPT_ACCESS_TOKEN": "$ARCANOS_GPT_ACCESS_TOKEN",
        "DEFAULT_GPT_ID": "$DEFAULT_GPT_ID",
        "OPENAI_ACTION_BRIDGE_WAIT_TIMEOUT_MS": "$OPENAI_ACTION_BRIDGE_WAIT_TIMEOUT_MS",
        "OPENAI_ACTION_BRIDGE_QUERY_WAIT_TIMEOUT_MS": "$OPENAI_ACTION_BRIDGE_QUERY_WAIT_TIMEOUT_MS",
        "OPENAI_ACTION_BRIDGE_POLL_INTERVAL_MS": "$OPENAI_ACTION_BRIDGE_POLL_INTERVAL_MS",
        "OPENAI_BASE_URL": "$OPENAI_BASE_URL",
        "AI_MODEL": "$AI_MODEL",
        "GPT51_MODEL": "$GPT51_MODEL",
        "GPT5_MODEL": "$GPT5_MODEL",
        "RAILWAY_ENVIRONMENT": "production",
        "ARCANOS_PROCESS_KIND": "$ARCANOS_PROCESS_KIND",
        "WORKER_API_TIMEOUT_MS": "60000",
        "JOB_WORKER_CONCURRENCY": "2",
        "DAG_MAX_CONCURRENT_NODES": "1",
        "JOB_WORKER_MAX_RETRIES": "2",
        "JOB_WORKER_RETRY_BASE_MS": "2000",
        "JOB_WORKER_RETRY_MAX_MS": "60000",
        "QUEUE_FAILED_JOB_CLEANUP_ENABLED": "true",
        "QUEUE_FAILED_JOB_RETENTION_COUNT": "50",
        "QUEUE_FAILED_JOB_CLEANUP_MIN_AGE_MS": "86400000",
        "ARC_LOG_PATH": "/tmp/arc/log",
        "ENABLE_ACTION_PLANS": "false",
        "ENABLE_CLEAR_2": "false"
      }
    },
    "development": {
      "variables": {
        "NODE_ENV": "development",
        "PORT": "8080",
        "DEFAULT_GPT_ID": "arcanos-core",
        "ARCANOS_PROCESS_KIND": "$ARCANOS_PROCESS_KIND",
        "RUN_WORKERS": "true"
      }
    }
  }
}
