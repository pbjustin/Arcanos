{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.arcanos.dev/protocol/v1/nouns/plan.schema.json",
  "title": "Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "status",
    "steps"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "approved",
        "executing",
        "completed"
      ]
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "description",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "in_progress",
              "completed",
              "failed"
            ]
          }
        }
      }
    }
  }
}
