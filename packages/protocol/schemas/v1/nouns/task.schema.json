{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.arcanos.dev/protocol/v1/nouns/task.schema.json",
  "title": "Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "command"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "payload": true,
    "context": {
      "$ref": "https://schemas.arcanos.dev/protocol/v1/nouns/context.schema.json"
    }
  }
}
