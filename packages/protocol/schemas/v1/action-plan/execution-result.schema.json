{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.arcanos.dev/protocol/v1/action-plan/execution-result.schema.json",
  "title": "ActionPlan execution result submission",
  "description": "Bounded result evidence for one existing action-level execution run. Identity fields are assertions only and never authorize the request.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "action_id",
    "snapshot_id",
    "outcome"
  ],
  "properties": {
    "action_id": {
      "$ref": "#/$defs/identifier"
    },
    "snapshot_id": {
      "$ref": "#/$defs/identifier"
    },
    "outcome": {
      "type": "string",
      "enum": [
        "succeeded",
        "failed"
      ]
    },
    "output": {
      "$ref": "#/$defs/jsonValue",
      "x-arcanos-max-encoded-bytes": 32768,
      "x-arcanos-max-depth": 8
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
        },
        "category": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
        }
      },
      "x-arcanos-max-encoded-bytes": 4096
    }
  },
  "x-arcanos-max-http-body-bytes": 65536,
  "x-arcanos-finite-numbers-only": true,
  "allOf": [
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "succeeded"
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "not": {
          "required": [
            "error"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "failed"
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "not": {
          "required": [
            "output"
          ]
        }
      }
    }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "jsonValue": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          }
        }
      ]
    }
  }
}
