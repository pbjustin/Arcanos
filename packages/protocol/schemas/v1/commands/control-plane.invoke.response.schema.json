{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.arcanos.dev/protocol/v1/commands/control-plane.invoke.response.schema.json",
  "title": "control-plane.invoke response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ok",
    "operation",
    "provider",
    "environment",
    "result",
    "auditId",
    "warnings",
    "redactedOutput"
  ],
  "properties": {
    "ok": {
      "type": "boolean"
    },
    "operation": {
      "type": "string",
      "minLength": 1
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "environment": {
      "type": "string",
      "minLength": 1
    },
    "result": true,
    "auditId": {
      "type": "string",
      "minLength": 1
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "redactedOutput": true,
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "details": true
      }
    }
  }
}
