{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.arcanos.dev/protocol/v1/envelope.schema.json",
  "title": "Arcanos Protocol v1 Envelope",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/request"
    },
    {
      "$ref": "#/$defs/response"
    }
  ],
  "$defs": {
    "protocol": {
      "type": "string",
      "const": "arcanos-v1"
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy",
        "token"
      ],
      "properties": {
        "strategy": {
          "type": "string",
          "minLength": 1
        },
        "token": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "context": {
      "$ref": "https://schemas.arcanos.dev/protocol/v1/nouns/context.schema.json"
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "message"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "traceId": {
          "type": "string"
        },
        "retryable": {
          "type": "boolean"
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": "string"
        },
        "executedBy": {
          "type": "string"
        },
        "timingMs": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol",
        "requestId",
        "command"
      ],
      "properties": {
        "protocol": {
          "$ref": "#/$defs/protocol"
        },
        "requestId": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "auth": {
          "$ref": "#/$defs/auth"
        },
        "context": {
          "$ref": "#/$defs/context"
        },
        "payload": true
      }
    },
    "response": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol",
        "requestId",
        "ok"
      ],
      "properties": {
        "protocol": {
          "$ref": "#/$defs/protocol"
        },
        "requestId": {
          "type": "string",
          "minLength": 1
        },
        "ok": {
          "type": "boolean"
        },
        "data": true,
        "error": {
          "$ref": "#/$defs/error"
        },
        "meta": {
          "$ref": "#/$defs/meta"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "ok": {
                "const": true
              }
            },
            "required": [
              "ok"
            ]
          },
          "then": {
            "not": {
              "required": [
                "error"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "ok": {
                "const": false
              }
            },
            "required": [
              "ok"
            ]
          },
          "then": {
            "required": [
              "error"
            ]
          }
        }
      ]
    }
  }
}
