{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.arcanos.dev/protocol/v1/tools/repo.listTree.input.schema.json",
  "title": "repo.listTree input",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "path": {
      "type": "string"
    },
    "depth": {
      "type": "integer",
      "minimum": 1,
      "maximum": 8,
      "default": 1
    },
    "includeHidden": {
      "type": "boolean",
      "default": false
    },
    "offset": {
      "type": "integer",
      "minimum": 0,
      "default": 0
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 500,
      "default": 200
    }
  }
}
