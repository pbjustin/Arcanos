{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.arcanos.dev/protocol/v1/nouns/context.schema.json",
  "title": "Context",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "sessionId": {
      "type": "string"
    },
    "projectId": {
      "type": "string"
    },
    "environment": {
      "type": "string"
    },
    "cwd": {
      "type": "string"
    },
    "shell": {
      "type": "string"
    },
    "caller": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "scopes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "integer",
              "boolean",
              "null"
            ]
          }
        }
      }
    }
  }
}
