{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.arcanos.dev/protocol/v1/nouns/run-result.schema.json",
  "title": "RunResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "startedAt"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "completed",
        "failed"
      ]
    },
    "exitCode": {
      "type": [
        "integer",
        "null"
      ]
    },
    "stdout": {
      "type": "string"
    },
    "stderr": {
      "type": "string"
    },
    "startedAt": {
      "type": "string"
    },
    "finishedAt": {
      "type": "string"
    }
  }
}
