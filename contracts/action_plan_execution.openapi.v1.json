              },
              "result_template": {
                "$ref": "#/components/schemas/Location"
              }
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "role": {
                  "const": "executor"
                }
              }
            },
            "then": {
              "required": [
                "executor_principal_id",
