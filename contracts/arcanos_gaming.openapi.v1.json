{
  "openapi": "3.1.0",
  "info": {
    "title": "ARCANOS Gaming Custom GPT Action",
    "version": "1.3.2",
    "description": "Builder-specific contract for ARCANOS Gaming. ARCANOS fetches and validates every source before producing grounded guidance."
  },
  "servers": [
    {
      "url": "https://acranos-production.up.railway.app",
      "description": "Canonical ARCANOS production deployment"
    }
  ],
  "paths": {
    "/gpt/arcanos-gaming": {
      "post": {
        "operationId": "queryArcanosGaming",
        "summary": "Ask ARCANOS Gaming",
        "description": "Submit a Gaming request and up to four untrusted candidate URLs for ARCANOS to fetch and validate.",
        "x-openai-isConsequential": false,
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GamingQueryRequest"
              },
              "examples": {
                "stableGuide": {
                  "summary": "Stable guide request",
                  "value": {
                    "action": "query",
                    "payload": {
                      "mode": "guide",
                      "game": "Elden Ring",
                      "prompt": "Look up a concise beginner guide for Elden Ring."
                    }
                  }
                },
                "currentGuide": {
                  "summary": "Version-sensitive guide request",
                  "value": {
                    "action": "query",
                    "payload": {
                      "mode": "guide",
                      "game": "Palworld",
                      "prompt": "Look up a current beginner-to-midgame guide for Palworld 1.0.",
                      "guideUrls": [
                        "https://example.com/palworld-1-0-guide",
                        "https://example.com/palworld-1-0-patch-notes"
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Gaming result, including a controlled evidence request when current evidence is unavailable.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GamingPublicResponse"
                }
              }
            }
          },
          "400": {
            "description": "Malformed or invalid request expressed as bounded JSON.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected route failure expressed as bounded JSON.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "GamingQueryRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "action",
          "payload"
        ],
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "query"
            ],
            "description": "Gaming dispatcher action."
          },
          "payload": {
            "$ref": "#/components/schemas/GamingQueryPayload"
          }
        }
      },
      "GamingQueryPayload": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "mode",
          "prompt"
        ],
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "guide",
              "build",
              "meta"
            ]
          },
          "game": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "prompt": {
            "type": "string",
            "minLength": 1,
            "maxLength": 8000
          },
          "url": {
            "type": "string",
            "format": "uri",
            "maxLength": 2048
          },
          "urls": {
            "type": "array",
            "maxItems": 4,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "format": "uri",
              "maxLength": 2048
            }
          },
          "guideUrl": {
            "type": "string",
            "format": "uri",
            "maxLength": 2048
          },
          "guideUrls": {
            "type": "array",
            "maxItems": 4,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "format": "uri",
              "maxLength": 2048
            }
          },
          "audit": {
            "type": "boolean"
          },
          "enableAudit": {
            "type": "boolean"
          },
          "hrc": {
            "type": "boolean"
          },
          "enableHrc": {
            "type": "boolean"
          }
        }
      },
      "GamingEvidenceRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "required",
          "reason",
          "game",
          "maxCandidateUrls",
          "queries"
        ],
        "properties": {
          "required": {
            "type": "boolean",
            "enum": [
              true
            ]
          },
          "reason": {
            "type": "string",
            "enum": [
              "CURRENT_VERSION_EVIDENCE_REQUIRED"
            ]
          },
          "game": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 3,
            "maxLength": 11,
            "pattern": "^[0-9]{1,3}\\.[0-9]{1,3}(?:\\.[0-9]{1,3})?$"
          },
          "maxCandidateUrls": {
            "type": "integer",
            "enum": [
              4
            ]
          },
          "queries": {
            "type": "array",
            "minItems": 1,
            "maxItems": 4,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 180
            }
          }
        }
      },
      "GamingSource": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string",
            "minLength": 1
          },
          "snippet": {
            "type": "string"
          },
          "error": {
            "type": "string"
          }
        }
      },
      "GamingResponseData": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "response",
          "sources"
        ],
        "properties": {
          "response": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4096,
            "pattern": "[\\p{L}\\p{N}\\p{S}]"
          },
          "sources": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GamingSource"
            }
          },
          "fallbackReason": {
            "type": "string"
          },
          "discoveryReason": {
            "type": "string"
          },
          "discoveryFailureReason": {
            "type": "string"
          },
          "evidenceRequest": {
            "$ref": "#/components/schemas/GamingEvidenceRequest"
          }
        }
      },
      "GamingResult": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "ok",
          "route",
          "mode"
        ],
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "route": {
            "type": "string",
            "enum": [
              "gaming"
            ]
          },
          "mode": {
            "type": "string",
            "enum": [
              "guide",
              "build",
              "meta"
            ]
          },
          "data": {
            "$ref": "#/components/schemas/GamingResponseData"
          },
          "error": {
            "$ref": "#/components/schemas/PublicError"
          }
        }
      },
      "GamingRouteMeta": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "requestId",
          "traceId"
        ],
        "properties": {
          "requestId": {
            "type": "string",
            "minLength": 1
          },
          "traceId": {
            "type": "string",
            "minLength": 1
          },
          "route": {
            "type": "string"
          },
          "module": {
            "type": "string"
          }
        }
      },
      "GamingPublicResponse": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "ok",
          "requestId",
          "traceId",
          "result",
          "_route"
        ],
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "requestId": {
            "type": "string",
            "minLength": 1
          },
          "traceId": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "$ref": "#/components/schemas/GamingResult"
          },
          "_route": {
            "$ref": "#/components/schemas/GamingRouteMeta"
          }
        }
      },
      "PublicError": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "details": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "PublicErrorResponse": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "ok",
          "requestId",
          "traceId",
          "error"
        ],
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "requestId": {
            "type": "string",
            "minLength": 1
          },
          "traceId": {
            "type": "string",
            "minLength": 1
          },
          "error": {
            "$ref": "#/components/schemas/PublicError"
          }
        }
      }
    }
  }
}
