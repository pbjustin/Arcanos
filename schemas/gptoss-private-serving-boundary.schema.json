{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arcanos.local/schemas/gptoss-private-serving-boundary.schema.json",
  "title": "GPT-OSS Private Serving Boundary Contract",
  "description": "Design-only schema for private GPT-OSS serving boundary envelopes. This schema does not define cryptographic implementation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "request", "response"],
  "properties": {
    "kind": { "const": "gptoss_private_serving_boundary" },
    "schemaVersion": { "const": 1 },
    "request": { "$ref": "#/$defs/signedRequestEnvelope" },
    "response": { "$ref": "#/$defs/responseEnvelope" },
    "denial": { "$ref": "#/$defs/denialResponse" },
    "rateLimit": { "$ref": "#/$defs/rateLimitResponse" },
    "authFailure": { "$ref": "#/$defs/authFailureResponse" },
    "replayProtectionPolicy": { "$ref": "#/$defs/replayProtectionPolicy" },
    "replayProtectionStoreStats": { "$ref": "#/$defs/replayProtectionStoreStats" },
    "replayProtectionDecision": { "$ref": "#/$defs/replayProtectionDecision" },
    "replayProtectionValidationReport": {
      "$ref": "#/$defs/replayProtectionValidationReport"
    },
    "durableReplayStoreDesign": { "$ref": "#/$defs/durableReplayStoreDesign" },
    "durableReplayStoreRecord": { "$ref": "#/$defs/durableReplayStoreRecord" },
    "durableReplayStorePolicy": { "$ref": "#/$defs/durableReplayStorePolicy" },
    "durableReplayStoreValidationReport": {
      "$ref": "#/$defs/durableReplayStoreValidationReport"
    },
    "durableReplayMigrationGuardReport": {
      "$ref": "#/$defs/durableReplayMigrationGuardReport"
    },
    "durableReplayMigrationGuardDecision": {
      "$ref": "#/$defs/durableReplayMigrationGuardDecision"
    },
    "durableReplayMigrationReadiness": {
      "$ref": "#/$defs/durableReplayMigrationReadiness"
    },
    "durableReplayImplementationReadinessReport": {
      "$ref": "#/$defs/durableReplayImplementationReadinessReport"
    },
    "durableReplaySecurityReview": {
      "$ref": "#/$defs/durableReplaySecurityReview"
    },
    "durableReplayRollbackReview": {
      "$ref": "#/$defs/durableReplayRollbackReview"
    }
  },
  "$defs": {
    "signedRequestEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requestId",
        "timestamp",
        "nonce",
        "audience",
        "signatureAlgorithm",
        "keyId",
        "bodyHash",
        "signature",
        "input"
      ],
      "properties": {
        "requestId": { "$ref": "#/$defs/nonEmptyString" },
        "timestamp": { "$ref": "#/$defs/dateTimeString" },
        "nonce": { "$ref": "#/$defs/nonceString" },
        "audience": { "const": "gptoss-effective-router-private" },
        "signatureAlgorithm": { "const": "hmac-sha256" },
        "keyId": { "$ref": "#/$defs/nonEmptyString" },
        "subject": { "$ref": "#/$defs/nonEmptyString" },
        "bodyHash": { "$ref": "#/$defs/sha256Hex" },
        "signature": { "$ref": "#/$defs/hmacSha256Signature" },
        "input": {
          "type": "object",
          "additionalProperties": false,
          "required": ["userInput", "mode"],
          "properties": {
            "userInput": { "$ref": "#/$defs/nonEmptyString" },
            "mode": { "const": "router_classifier" }
          }
        }
      }
    },
    "scaffoldSignedRequestEnvelope": {
      "$ref": "#/$defs/signedRequestEnvelope"
    },
    "requestIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requestId", "subject", "keyId", "audience"],
      "properties": {
        "requestId": { "$ref": "#/$defs/nonEmptyString" },
        "subject": { "$ref": "#/$defs/nonEmptyString" },
        "keyId": { "$ref": "#/$defs/nonEmptyString" },
        "audience": { "const": "gptoss-effective-router-private" }
      }
    },
    "keyDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["keyId", "subject"],
      "properties": {
        "keyId": { "$ref": "#/$defs/nonEmptyString" },
        "subject": { "$ref": "#/$defs/nonEmptyString" },
        "label": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "authFailure": {
      "type": "string",
      "enum": [
        "missing_request_id",
        "missing_timestamp",
        "missing_nonce",
        "missing_audience",
        "missing_body_hash",
        "missing_signature",
        "invalid_signature",
        "invalid_audience",
        "stale_timestamp",
        "future_timestamp",
        "invalid_nonce",
        "missing_key_id",
        "unknown_key_id",
        "replay_check_unavailable",
        "replay_store_unavailable",
        "replay_detected",
        "subject_unavailable",
        "signature_verification_unavailable",
        "signature_verification_not_implemented",
        "authentication_failure"
      ]
    },
    "authDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "authenticated", "implemented", "requestId"],
      "properties": {
        "ok": { "type": "boolean" },
        "authenticated": { "type": "boolean" },
        "implemented": { "const": true },
        "requestId": { "type": ["string", "null"] },
        "subject": { "$ref": "#/$defs/nonEmptyString" },
        "keyId": { "$ref": "#/$defs/nonEmptyString" },
        "audience": { "const": "gptoss-effective-router-private" },
        "replayProtectionRequired": { "const": true },
        "timestampAccepted": { "const": true },
        "nonceAccepted": { "const": true },
        "signatureAccepted": { "const": true },
        "denialReason": {
          "anyOf": [
            { "const": null },
            { "$ref": "#/$defs/authFailure" }
          ]
        },
        "safeToExpose": { "const": true }
      }
    },
    "replayProtectionDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ok",
        "replayAccepted",
        "implemented",
        "keyId",
        "nonce",
        "requestId",
        "bodyHash",
        "recorded",
        "denialReason"
      ],
      "properties": {
        "ok": { "type": "boolean" },
        "replayAccepted": { "type": "boolean" },
        "implemented": { "const": true },
        "keyId": { "type": ["string", "null"] },
        "nonce": { "type": ["string", "null"] },
        "requestId": { "type": ["string", "null"] },
        "bodyHash": { "type": ["string", "null"] },
        "recorded": { "type": "boolean" },
        "denialReason": {
          "anyOf": [
            { "const": null },
            { "$ref": "#/$defs/authFailure" }
          ]
        }
      }
    },
    "replayProtectionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "implemented",
        "durable",
        "replayWindowSeconds",
        "maxFutureSkewSeconds",
        "noncePattern"
      ],
      "properties": {
        "implemented": { "const": true },
        "durable": { "const": false },
        "replayWindowSeconds": { "type": "integer", "minimum": 0 },
        "maxFutureSkewSeconds": { "type": "integer", "minimum": 0 },
        "noncePattern": { "const": "^[A-Za-z0-9_-]{16,128}$" },
        "now": { "type": "number" }
      }
    },
    "replayProtectionStoreStats": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "implemented",
        "durable",
        "available",
        "entries",
        "keyIds",
        "nonces",
        "oldestTimestamp",
        "newestTimestamp"
      ],
      "properties": {
        "implemented": { "const": true },
        "durable": { "const": false },
        "available": { "type": "boolean" },
        "entries": { "type": "integer", "minimum": 0 },
        "keyIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "nonces": {
          "type": "array",
          "items": { "type": "string" }
        },
        "oldestTimestamp": {
          "anyOf": [
            { "const": null },
            { "$ref": "#/$defs/dateTimeString" }
          ]
        },
        "newestTimestamp": {
          "anyOf": [
            { "const": null },
            { "$ref": "#/$defs/dateTimeString" }
          ]
        }
      }
    },
    "replayProtectionValidationReport": {
      "type": "object",
      "additionalProperties": true,
      "required": ["policy", "decisions", "storeStats", "pruneStoreStats"],
      "properties": {
        "policy": { "$ref": "#/$defs/replayProtectionPolicy" },
        "decisions": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/replayProtectionDecision" }
        },
        "prune": {
          "type": "object",
          "additionalProperties": true,
          "required": ["ok", "implemented", "pruned", "denialReason"],
          "properties": {
            "ok": { "type": "boolean" },
            "implemented": { "const": true },
            "pruned": { "type": "integer", "minimum": 0 },
            "denialReason": {
              "anyOf": [
                { "const": null },
                { "$ref": "#/$defs/authFailure" }
              ]
            }
          }
        },
        "storeStats": { "$ref": "#/$defs/replayProtectionStoreStats" },
        "pruneStoreStats": { "$ref": "#/$defs/replayProtectionStoreStats" }
      }
    },
    "durableReplayAuditCorrelation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requestId", "bodyHash", "keyId", "traceId", "auditRecordId"],
      "properties": {
        "requestId": { "$ref": "#/$defs/nonEmptyString" },
        "bodyHash": { "$ref": "#/$defs/sha256Hex" },
        "keyId": { "$ref": "#/$defs/nonEmptyString" },
        "subjectHash": { "$ref": "#/$defs/sha256Hex" },
        "traceId": { "$ref": "#/$defs/nonEmptyString" },
        "auditRecordId": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "durableReplayStoreRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "keyId",
        "nonce",
        "uniquenessScope",
        "requestId",
        "bodyHash",
        "timestamp",
        "receivedAt",
        "expiresAt",
        "auditCorrelation",
        "rawRequestBodyStored",
        "secretsStored"
      ],
      "properties": {
        "schemaVersion": { "const": 1 },
        "keyId": { "$ref": "#/$defs/nonEmptyString" },
        "nonce": { "$ref": "#/$defs/nonceString" },
        "uniquenessScope": { "const": "keyId+nonce" },
        "requestId": { "$ref": "#/$defs/nonEmptyString" },
        "bodyHash": { "$ref": "#/$defs/sha256Hex" },
        "timestamp": { "$ref": "#/$defs/dateTimeString" },
        "receivedAt": { "$ref": "#/$defs/dateTimeString" },
        "expiresAt": { "$ref": "#/$defs/dateTimeString" },
        "auditCorrelation": { "$ref": "#/$defs/durableReplayAuditCorrelation" },
        "rawRequestBodyStored": { "const": false },
        "secretsStored": { "const": false }
      }
    },
    "durableReplayStorePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "designed",
        "implemented",
        "durable",
        "uniquenessRule",
        "timestampWindowSeconds",
        "maxFutureSkewSeconds",
        "ttlSeconds",
        "pruningPolicy",
        "failureMode",
        "migrationSafety",
        "rollbackBehavior",
        "noRawRequestBodyStorage",
        "noSecretStorage",
        "liveDbAccessInPhase"
      ],
      "properties": {
        "designed": { "const": true },
        "implemented": { "const": false },
        "durable": { "const": false },
        "uniquenessRule": { "const": "keyId+nonce" },
        "timestampWindowSeconds": { "type": "integer", "minimum": 1 },
        "maxFutureSkewSeconds": { "type": "integer", "minimum": 0 },
        "ttlSeconds": { "type": "integer", "minimum": 1 },
        "pruningPolicy": {
          "type": "string",
          "enum": ["delete_after_expires_at", "partition_or_batch_prune_after_ttl"]
        },
        "failureMode": { "const": "fail_closed" },
        "migrationSafety": { "const": "design_only_no_live_migration" },
        "rollbackBehavior": { "const": "disable_private_serving_keep_existing_replay_blocks" },
        "noRawRequestBodyStorage": { "const": true },
        "noSecretStorage": { "const": true },
        "liveDbAccessInPhase": { "const": false }
      }
    },
    "durableReplayStoreDesign": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "phase",
        "designed",
        "implemented",
        "durable",
        "purpose",
        "record",
        "policy"
      ],
      "properties": {
        "schemaVersion": { "const": 1 },
        "phase": { "const": "5.5" },
        "designed": { "const": true },
        "implemented": { "const": false },
        "durable": { "const": false },
        "purpose": { "$ref": "#/$defs/nonEmptyString" },
        "record": { "$ref": "#/$defs/durableReplayStoreRecord" },
        "policy": { "$ref": "#/$defs/durableReplayStorePolicy" }
      }
    },
    "durableReplayStoreValidationReport": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schemaVersion",
        "kind",
        "ok",
        "durableReplayStoreDesigned",
        "replayProtectionDurableDesigned",
        "replayProtectionDurableImplemented",
        "replayProtectionDurable",
        "privateServingImplemented",
        "privateServingExposed",
        "cloudReady",
        "customGptReady",
        "openAiCalled",
        "trainingExecuted",
        "vllmUsed",
        "railwayCliUsed",
        "liveDbUsed",
        "serverCreated",
        "failures"
      ],
      "properties": {
        "schemaVersion": { "const": 1 },
        "kind": {
          "const": "gptoss_private_serving_durable_replay_store_design_validation"
        },
        "ok": { "type": "boolean" },
        "durableReplayStoreDesigned": { "const": true },
        "replayProtectionDurableDesigned": { "const": true },
        "replayProtectionDurableImplemented": { "const": false },
        "replayProtectionDurable": { "const": false },
        "privateServingImplemented": { "const": false },
        "privateServingExposed": { "const": false },
        "cloudReady": { "const": false },
        "customGptReady": { "const": false },
        "openAiCalled": { "const": false },
        "trainingExecuted": { "const": false },
        "vllmUsed": { "const": false },
        "railwayCliUsed": { "const": false },
        "liveDbUsed": { "const": false },
        "serverCreated": { "const": false },
        "failures": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "durableReplayMigrationGuardDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "migrationDraftReady",
        "applyAllowed",
        "liveDbWrite",
        "durableReplayMigrationApplied",
        "failures"
      ],
      "properties": {
        "migrationDraftReady": { "type": "boolean" },
        "applyAllowed": { "const": false },
        "liveDbWrite": { "const": false },
        "durableReplayMigrationApplied": { "const": false },
        "failures": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "durableReplayMigrationReadiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "migrationDraftReady",
        "applyAllowed",
        "liveDbWrite",
        "durableReplayMigrationApplied",
        "failures"
      ],
      "properties": {
        "migrationDraftReady": { "type": "boolean" },
        "applyAllowed": { "const": false },
        "liveDbWrite": { "const": false },
        "durableReplayMigrationApplied": { "const": false },
        "failures": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "durableReplayMigrationGuardReport": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schemaVersion",
        "kind",
        "ok",
        "migrationDraftReady",
        "applyAllowed",
        "liveDbWrite",
        "durableReplayMigrationApplied",
        "failures"
      ],
      "properties": {
        "schemaVersion": { "const": 1 },
        "kind": {
          "const": "gptoss_private_serving_durable_replay_migration_guard"
        },
        "ok": { "type": "boolean" },
        "migrationDraftReady": { "type": "boolean" },
        "applyAllowed": { "const": false },
        "liveDbWrite": { "const": false },
        "durableReplayMigrationApplied": { "const": false },
        "failures": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "durableReplayImplementationReadinessReport": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schemaVersion",
        "kind",
        "ok",
        "durableReplayImplementationReady",
        "replayProtectionDurableDesigned",
        "replayProtectionDurableImplemented",
        "replayProtectionDurable",
        "privateServingImplemented",
        "privateServingExposed",
        "cloudReady",
        "customGptReady",
        "migrationGuardExists",
        "migrationApplyBlocked",
        "durableReplayMigrationApplied",
        "liveDbUsed",
        "liveDbWrite",
        "serverCreated",
        "openAiCalled",
        "trainingExecuted",
        "vllmUsed",
        "railwayCliUsed",
        "noDbImplementation",
        "noServerImplementation",
        "noExposurePath",
        "failures"
      ],
      "properties": {
        "schemaVersion": { "const": 1 },
        "kind": {
          "const": "gptoss_private_serving_durable_replay_implementation_readiness"
        },
        "ok": { "type": "boolean" },
        "durableReplayImplementationReady": { "const": true },
        "replayProtectionDurableDesigned": { "const": true },
        "replayProtectionDurableImplemented": { "const": false },
        "replayProtectionDurable": { "const": false },
        "privateServingImplemented": { "const": false },
        "privateServingExposed": { "const": false },
        "cloudReady": { "const": false },
        "customGptReady": { "const": false },
        "migrationGuardExists": { "const": true },
        "migrationApplyBlocked": { "const": true },
        "durableReplayMigrationApplied": { "const": false },
        "liveDbUsed": { "const": false },
        "liveDbWrite": { "const": false },
        "serverCreated": { "const": false },
        "openAiCalled": { "const": false },
        "trainingExecuted": { "const": false },
        "vllmUsed": { "const": false },
        "railwayCliUsed": { "const": false },
        "noDbImplementation": { "const": true },
        "noServerImplementation": { "const": true },
        "noExposurePath": { "const": true },
        "failures": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "durableReplaySecurityReview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "kind",
        "ok",
        "noRawNonceStorage",
        "noRawBodyStorage",
        "noSecretStorage",
        "noSignatureStorage",
        "noOpenAiContamination",
        "noTrainingDataIngestion",
        "noDbAccessInCurrentPhase",
        "noEndpointExposure",
        "noCustomGptAccess",
        "durableReplayImplementationAllowed",
        "failures"
      ],
      "properties": {
        "schemaVersion": { "const": 1 },
        "kind": { "const": "gptoss_private_serving_durable_replay_security_review" },
        "ok": { "type": "boolean" },
        "noRawNonceStorage": { "const": true },
        "noRawBodyStorage": { "const": true },
        "noSecretStorage": { "const": true },
        "noSignatureStorage": { "const": true },
        "noOpenAiContamination": { "const": true },
        "noTrainingDataIngestion": { "const": true },
        "noDbAccessInCurrentPhase": { "const": true },
        "noEndpointExposure": { "const": true },
        "noCustomGptAccess": { "const": true },
        "durableReplayImplementationAllowed": { "const": false },
        "failures": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "durableReplayRollbackReview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "kind",
        "ok",
        "migrationRollbackStrategyDocumented",
        "featureDisableStrategyDocumented",
        "replayFallbackBehaviorDocumented",
        "auditPreservationDocumented",
        "incidentRecoveryChecklistDocumented",
        "failClosedRequirementsDocumented",
        "executableRollbackCode",
        "cloudReady",
        "customGptReady",
        "failures"
      ],
      "properties": {
        "schemaVersion": { "const": 1 },
        "kind": { "const": "gptoss_private_serving_durable_replay_rollback_review" },
        "ok": { "type": "boolean" },
        "migrationRollbackStrategyDocumented": { "const": true },
        "featureDisableStrategyDocumented": { "const": true },
        "replayFallbackBehaviorDocumented": { "const": true },
        "auditPreservationDocumented": { "const": true },
        "incidentRecoveryChecklistDocumented": { "const": true },
        "failClosedRequirementsDocumented": { "const": true },
        "executableRollbackCode": { "const": false },
        "cloudReady": { "const": false },
        "customGptReady": { "const": false },
        "failures": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "scaffoldAuthDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "authenticated", "failClosed", "implemented", "reason"],
      "properties": {
        "ok": { "type": "boolean" },
        "authenticated": { "type": "boolean" },
        "failClosed": { "type": "boolean" },
        "implemented": { "const": false },
        "testOnly": { "type": "boolean" },
        "reason": {
          "type": ["string", "null"],
          "enum": [
            null,
            "missing_request_id",
            "missing_timestamp",
            "missing_nonce",
            "missing_audience",
            "missing_body_hash",
            "missing_signature",
            "invalid_audience",
            "stale_timestamp",
            "invalid_nonce",
            "signature_verification_unavailable",
            "signature_verification_not_implemented",
            "invalid_signature"
          ]
        },
        "requestId": { "type": ["string", "null"] },
        "audience": { "const": "gptoss-effective-router-private" },
        "cloudReady": { "const": false },
        "customGptReady": { "const": false },
        "privateServingExposed": { "const": false },
        "publicServerCreated": { "const": false }
      }
    },
    "scaffoldRateLimitDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "allowed", "reason", "retryAfterSeconds"],
      "properties": {
        "ok": { "type": "boolean" },
        "allowed": { "type": "boolean" },
        "reason": {
          "type": ["string", "null"],
          "enum": [null, "missing_subject", "invalid_rate_limit_policy", "rate_limited"]
        },
        "retryAfterSeconds": { "type": "integer", "minimum": 0 },
        "remaining": { "type": "integer", "minimum": 0 },
        "policy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["maxRequestsPerMinute", "burstLimit"],
          "properties": {
            "maxRequestsPerMinute": { "const": 30 },
            "burstLimit": { "const": 5 }
          }
        }
      }
    },
    "scaffoldSafeResponseEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requestId", "effective", "safety"],
      "properties": {
        "requestId": { "$ref": "#/$defs/nonEmptyString" },
        "effective": { "$ref": "#/$defs/effectiveResult" },
        "safety": { "$ref": "#/$defs/safetyFlags" }
      }
    },
    "scaffoldDenialResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "denied", "reason", "requestId", "safety"],
      "properties": {
        "ok": { "const": false },
        "denied": { "const": true },
        "reason": { "$ref": "#/$defs/nonEmptyString" },
        "requestId": { "$ref": "#/$defs/nonEmptyString" },
        "retryAfterSeconds": { "type": "integer", "minimum": 1 },
        "safety": { "$ref": "#/$defs/safetyFlags" }
      }
    },
    "scaffoldValidationReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ok",
        "privateServingDesignReady",
        "privateServingScaffoldReady",
        "requestSigningImplemented",
        "authBoundaryImplemented",
        "replayProtectionScaffoldReady",
        "replayProtectionImplemented",
        "replayProtectionDurableDesigned",
        "replayProtectionDurableImplemented",
        "replayProtectionDurable",
        "privateServingImplemented",
        "privateServingExposed",
        "publicServerCreated",
        "cloudReady",
        "customGptReady",
        "openAiCalled",
        "trainingExecuted",
        "vllmUsed",
        "railwayCliUsed",
        "liveDbUsed",
        "serverCreated",
        "failures",
        "scripts",
        "docs",
        "tests"
      ],
      "properties": {
        "ok": { "type": "boolean" },
        "privateServingDesignReady": { "const": true },
        "privateServingScaffoldReady": { "const": true },
        "requestSigningImplemented": { "const": true },
        "authBoundaryImplemented": { "const": true },
        "replayProtectionScaffoldReady": { "const": true },
        "replayProtectionImplemented": { "const": true },
        "replayProtectionDurableDesigned": { "const": true },
        "replayProtectionDurableImplemented": { "const": false },
        "replayProtectionDurable": { "const": false },
        "privateServingImplemented": { "const": false },
        "privateServingExposed": { "const": false },
        "publicServerCreated": { "const": false },
        "cloudReady": { "const": false },
        "customGptReady": { "const": false },
        "openAiCalled": { "const": false },
        "trainingExecuted": { "const": false },
        "vllmUsed": { "const": false },
        "railwayCliUsed": { "const": false },
        "liveDbUsed": { "const": false },
        "serverCreated": { "const": false },
        "noOpenAiOutputUsed": { "const": true },
        "failures": {
          "type": "array",
          "items": { "type": "string" }
        },
        "scripts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "docs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tests": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "responseEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requestId", "effective", "safety", "audit", "replay", "readiness"],
      "properties": {
        "requestId": { "$ref": "#/$defs/nonEmptyString" },
        "effective": { "$ref": "#/$defs/effectiveResult" },
        "safety": { "$ref": "#/$defs/safetyFlags" },
        "audit": { "$ref": "#/$defs/auditMetadata" },
        "replay": { "$ref": "#/$defs/replayMetadata" },
        "readiness": { "$ref": "#/$defs/readinessFlags" }
      }
    },
    "safetyFlags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "openAiCalled",
        "trainingExecuted",
        "vllmUsed",
        "railwayCliUsed",
        "liveDbUsed",
        "noOpenAiOutputUsed"
      ],
      "properties": {
        "openAiCalled": { "const": false },
        "trainingExecuted": { "const": false },
        "vllmUsed": { "const": false },
        "railwayCliUsed": { "const": false },
        "liveDbUsed": { "const": false },
        "noOpenAiOutputUsed": { "const": true }
      }
    },
    "auditMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["auditVersion", "requestId", "timestamp", "bodyHash", "decision"],
      "properties": {
        "auditVersion": { "const": 1 },
        "requestId": { "$ref": "#/$defs/nonEmptyString" },
        "timestamp": { "$ref": "#/$defs/dateTimeString" },
        "bodyHash": { "$ref": "#/$defs/sha256Hex" },
        "decision": {
          "type": "string",
          "enum": ["allowed", "denied", "rate_limited", "auth_failed"]
        }
      }
    },
    "replayMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["replayable", "requestHash", "nonce"],
      "properties": {
        "replayable": { "type": "boolean" },
        "requestHash": { "$ref": "#/$defs/sha256Hex" },
        "nonce": { "$ref": "#/$defs/nonceString" }
      }
    },
    "denialResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requestId", "error", "safety", "audit", "replay", "readiness"],
      "properties": {
        "requestId": { "$ref": "#/$defs/nonEmptyString" },
        "error": {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message"],
          "properties": {
            "code": { "const": "DENIED" },
            "message": { "$ref": "#/$defs/nonEmptyString" }
          }
        },
        "safety": { "$ref": "#/$defs/safetyFlags" },
        "audit": { "$ref": "#/$defs/auditMetadata" },
        "replay": { "$ref": "#/$defs/replayMetadata" },
        "readiness": { "$ref": "#/$defs/readinessFlags" }
      }
    },
    "rateLimitResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requestId", "error", "retryAfterSeconds", "audit", "replay", "readiness"],
      "properties": {
        "requestId": { "$ref": "#/$defs/nonEmptyString" },
        "error": {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message"],
          "properties": {
            "code": { "const": "RATE_LIMITED" },
            "message": { "$ref": "#/$defs/nonEmptyString" }
          }
        },
        "retryAfterSeconds": { "type": "integer", "minimum": 1 },
        "audit": { "$ref": "#/$defs/auditMetadata" },
        "replay": { "$ref": "#/$defs/replayMetadata" },
        "readiness": { "$ref": "#/$defs/readinessFlags" }
      }
    },
    "authFailureResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requestId", "error", "audit", "replay", "readiness"],
      "properties": {
        "requestId": { "$ref": "#/$defs/nonEmptyString" },
        "error": {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message"],
          "properties": {
            "code": { "const": "AUTH_FAILED" },
            "message": { "$ref": "#/$defs/nonEmptyString" }
          }
        },
        "audit": { "$ref": "#/$defs/auditMetadata" },
        "replay": { "$ref": "#/$defs/replayMetadata" },
        "readiness": { "$ref": "#/$defs/readinessFlags" }
      }
    },
    "effectiveResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plane",
        "action",
        "risk",
        "requiresConfirmation",
        "allowedForTraining",
        "sources"
      ],
      "properties": {
        "plane": { "enum": ["writing-plane", "control-plane"] },
        "action": { "$ref": "#/$defs/nonEmptyString" },
        "risk": { "$ref": "#/$defs/nonEmptyString" },
        "requiresConfirmation": { "type": "boolean" },
        "allowedForTraining": { "const": false },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": ["model", "policy", "spec_facts", "postprocessor"]
          }
        }
      }
    },
    "readinessFlags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "privateServingDesignReady",
        "privateServingScaffoldReady",
        "privateServingImplemented",
        "privateServingExposed",
        "requestSigningDesigned",
        "requestSigningScaffoldReady",
        "requestSigningImplemented",
        "authBoundaryDesigned",
        "authBoundaryScaffoldReady",
        "authBoundaryImplemented",
        "replayProtectionScaffoldReady",
        "replayProtectionImplemented",
        "replayProtectionDurableDesigned",
        "replayProtectionDurableImplemented",
        "replayProtectionDurable",
        "rateLimitScaffoldReady",
        "rateLimitImplemented",
        "responseShapingScaffoldReady",
        "publicServerCreated",
        "cloudReady",
        "customGptReady"
      ],
      "properties": {
        "privateServingDesignReady": { "const": true },
        "privateServingScaffoldReady": { "const": true },
        "privateServingImplemented": { "const": false },
        "privateServingExposed": { "const": false },
        "requestSigningDesigned": { "const": true },
        "requestSigningScaffoldReady": { "const": true },
        "requestSigningImplemented": { "const": true },
        "authBoundaryDesigned": { "const": true },
        "authBoundaryScaffoldReady": { "const": true },
        "authBoundaryImplemented": { "const": true },
        "replayProtectionScaffoldReady": { "const": true },
        "replayProtectionImplemented": { "const": true },
        "replayProtectionDurableDesigned": { "const": true },
        "replayProtectionDurableImplemented": { "const": false },
        "replayProtectionDurable": { "const": false },
        "rateLimitScaffoldReady": { "const": true },
        "rateLimitImplemented": { "const": false },
        "responseShapingScaffoldReady": { "const": true },
        "publicServerCreated": { "const": false },
        "cloudReady": { "const": false },
        "customGptReady": { "const": false }
      }
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "dateTimeString": {
      "type": "string",
      "minLength": 1
    },
    "nonceString": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]{16,128}$"
    },
    "sha256Hex": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "hmacSha256Signature": {
      "type": "string",
      "pattern": "^hmac-sha256:[a-f0-9]{64}$"
    }
  }
}
