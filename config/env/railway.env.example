# Railway deployment variables

RAILWAY_PROJECT=arcanos-core
RAILWAY_ENVIRONMENT=production

# Optional project/service metadata
# RAILWAY_PROJECT_ID=
# RAILWAY_SERVICE_ID=
# RAILWAY_DEPLOYMENT_ID=
# RAILWAY_RELEASE_ID=

# Railway management API
# RAILWAY_API_TOKEN=
# RAILWAY_GRAPHQL_ENDPOINT=https://backboard.railway.app/graphql/v2
# RAILWAY_GRAPHQL_TIMEOUT_MS=15000

# OpenAI and GPT access
# OPENAI_API_KEY=
# OPENAI_API_KEY_REQUIRED=true
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_ACTION_SHARED_SECRET=
# ARCANOS_GPT_ACCESS_TOKEN=
# ARCANOS_GPT_ACCESS_BASE_URL=https://your-service.up.railway.app
# ARCANOS_GPT_ACCESS_SCOPES=runtime.read,workers.read,queue.read,jobs.create,jobs.result,logs.read_sanitized,db.explain_approved,mcp.approved_readonly,diagnostics.read
# Add capabilities.read/capabilities.run only when direct capability discovery/execution is required.
# Required only when capabilities.run or MCP modules.invoke should execute allowed actions.
# MCP_ALLOW_MODULE_ACTIONS=ARCANOS:CORE:query
# RAILWAY_OPENAI_API_KEY=
# RAILWAY_OPENAI_MODEL=
# RAILWAY_OPENAI_FALLBACK_MODEL=

# Service role and worker behavior
# ARCANOS_PROCESS_KIND=web
# RUN_WORKERS=false
# WORKER_API_TIMEOUT_MS=60000
# JOB_WORKER_CONCURRENCY=2
# JOB_WORKER_HEARTBEAT_MS=10000
# JOB_WORKER_LEASE_MS=30000
# JOB_WORKER_STALE_AFTER_MS=60000
# JOB_WORKER_MAX_RETRIES=2
# JOB_WORKER_RETRY_BASE_MS=2000
# JOB_WORKER_RETRY_MAX_MS=60000
# QUEUE_FAILED_JOB_CLEANUP_ENABLED=true
# QUEUE_FAILED_JOB_RETENTION_COUNT=50
# QUEUE_FAILED_JOB_CLEANUP_MIN_AGE_MS=86400000

# Public endpoint hints
# API_URL=https://your-service.up.railway.app
# BACKEND_REGISTRY_URL=https://your-service.up.railway.app/registry
