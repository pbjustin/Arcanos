    "status": "action-plan-execution-status-v1",
    "result_read": "action-plan-execution-result-read-v1"
  },
  "jsonDepthCases": [
    {
      "name": "empty container at maximum depth",
      "value": { "d": { "d": { "d": { "d": { "d": { "d": { "d": {} } } } } } } },
      "valid": true
    },
    {
      "name": "value beyond maximum depth",
      "value": { "d": { "d": { "d": { "d": { "d": { "d": { "d": { "d": {} } } } } } } } },
      "valid": false
    }
  ],
  "identifierCases": [
    { "name": "canonical action identifier", "value": "action-001", "valid": true },
    { "name": "identifier with space", "value": "bad id", "valid": false },
    { "name": "identifier with slash", "value": "bad/id", "valid": false },
    { "name": "identifier over maximum", "value": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa", "valid": false }
  ],
  "valid": {
