{
  "protocolVersion": "action-plan-execution-v1",
  "persistedProtocolVersion": 2,
  "snapshotVersion": "action-execution-snapshot-v1",
  "limits": {
    "maxHttpBodyBytes": 65536,
    "maxOutputBytes": 32768,
    "maxErrorBytes": 4096,
    "maxSnapshotBytes": 32768,
    "maxJsonDepth": 8,
    "maxIdCharacters": 128,
    "maxRealmCharacters": 256,
    "maxIdempotencyKeyCharacters": 256,
    "maxErrorCodeCharacters": 64,
    "maxLocationCharacters": 512
  },
  "schemaVersions": {
    "command": "action-plan-execution-command-v1",
