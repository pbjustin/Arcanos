  "invalid": [
    {
      "name": "result-shaped command requires dedicated endpoint",
      "schema": "command",
      "value": {
        "action_id": "action-001",
        "snapshot_id": "snapshot-001",
        "outcome": "succeeded"
      },
      "expected_code": "ACTION_PLAN_RESULT_ENDPOINT_REQUIRED"
    },
    {
      "name": "ambiguous command field is rejected",
      "schema": "command",
      "value": {
        "operation": "execute"
      },
      "expected_code": "ACTION_PLAN_EXECUTION_REQUEST_INVALID"
    },
    {
      "name": "caller cannot select claim owner",
      "schema": "claim",
      "value": {
        "owner": "caller-selected-owner"
      },
      "expected_code": "ACTION_PLAN_EXECUTION_REQUEST_INVALID"
    },
    {
      "name": "caller cannot select start realm",
      "schema": "start",
      "value": {
        "execution_realm": "caller-selected-realm"
      },
      "expected_code": "ACTION_PLAN_EXECUTION_REQUEST_INVALID"
    },
    {
      "name": "result owner field is rejected",
      "schema": "result",
      "value": {
        "action_id": "action-001",
        "snapshot_id": "snapshot-001",
        "outcome": "succeeded",
        "owner": "caller-selected-owner"
      },
      "expected_code": "ACTION_PLAN_EXECUTION_REQUEST_INVALID"
    },
    {
      "name": "result executor kind field is rejected",
      "schema": "result",
      "value": {
        "action_id": "action-001",
        "snapshot_id": "snapshot-001",
        "outcome": "succeeded",
        "executor_kind": "backend-inline"
      },
      "expected_code": "ACTION_PLAN_EXECUTION_REQUEST_INVALID"
    },
    {
      "name": "result realm field is rejected",
      "schema": "result",
      "value": {
        "action_id": "action-001",
        "snapshot_id": "snapshot-001",
        "outcome": "succeeded",
        "execution_realm": "caller-selected-realm"
      },
      "expected_code": "ACTION_PLAN_EXECUTION_REQUEST_INVALID"
    },
    {
      "name": "result command field is rejected",
      "schema": "result",
      "value": {
        "action_id": "action-001",
        "snapshot_id": "snapshot-001",
        "outcome": "succeeded",
        "command": "synthetic command"
      },
      "expected_code": "ACTION_PLAN_EXECUTION_REQUEST_INVALID"
    },
    {
      "name": "result clear field is rejected",
      "schema": "result",
      "value": {
        "action_id": "action-001",
        "snapshot_id": "snapshot-001",
        "outcome": "succeeded",
        "clear_decision": "allow"
      },
      "expected_code": "ACTION_PLAN_EXECUTION_REQUEST_INVALID"
    },
    {
      "name": "result lifecycle field is rejected",
      "schema": "result",
      "value": {
        "action_id": "action-001",
        "snapshot_id": "snapshot-001",
        "outcome": "succeeded",
        "plan_status": "approved"
      },
      "expected_code": "ACTION_PLAN_EXECUTION_REQUEST_INVALID"
    },
    {
      "name": "result missing action identity is rejected",
      "schema": "result",
      "value": {
        "snapshot_id": "snapshot-001",
        "outcome": "succeeded"
      },
      "expected_code": "ACTION_PLAN_EXECUTION_REQUEST_INVALID"
    },
    {
      "name": "unknown terminal outcome is rejected",
      "schema": "result",
      "value": {
        "action_id": "action-001",
        "snapshot_id": "snapshot-001",
        "outcome": "completed"
      },
      "expected_code": "ACTION_PLAN_EXECUTION_REQUEST_INVALID"
    },
    {
      "name": "raw error message is rejected",
      "schema": "result",
      "value": {
        "action_id": "action-002",
        "snapshot_id": "snapshot-002",
        "outcome": "failed",
        "error": {
          "code": "LOCAL_COMMAND_FAILED",
          "message": "raw dependency detail"
        }
      },
      "expected_code": "ACTION_PLAN_EXECUTION_REQUEST_INVALID"
    },
    {
      "name": "successful outcome with error evidence is rejected",
      "schema": "result",
      "value": {
        "action_id": "action-001",
        "snapshot_id": "snapshot-001",
        "outcome": "succeeded",
        "error": {
          "code": "CONTRADICTORY_RESULT"
        }
      },
      "expected_code": "ACTION_PLAN_EXECUTION_REQUEST_INVALID"
    },
    {
      "name": "failed outcome with success output is rejected",
      "schema": "result",
      "value": {
        "action_id": "action-002",
        "snapshot_id": "snapshot-002",
        "outcome": "failed",
        "output": {
          "completed": true
        }
      },
      "expected_code": "ACTION_PLAN_EXECUTION_REQUEST_INVALID"
    }
  ],
  "idempotencyDecisions": [
    {
      "name": "same command key and same canonical request replays",
      "operation": "request-execution",
      "same_key": true,
      "same_fingerprint": true,
      "expected_disposition": "COMMAND_REPLAY",
      "expected_code": "ACTION_PLAN_EXECUTION_COMMAND_ACCEPTED",
      "expected_new_runs": 0
    },
    {
      "name": "same command key and different request conflicts",
      "operation": "request-execution",
      "same_key": true,
      "same_fingerprint": false,
      "expected_disposition": "CONFLICT",
      "expected_code": "ACTION_PLAN_EXECUTION_IDEMPOTENCY_CONFLICT",
      "expected_new_runs": 0
    },
    {
      "name": "same result key and same evidence replays",
      "operation": "submit-result",
      "same_key": true,
      "same_fingerprint": true,
      "expected_disposition": "RESULT_REPLAY",
      "expected_code": "ACTION_PLAN_EXECUTION_RESULT_ACCEPTED",
      "expected_terminal_transitions": 0
    },
    {
      "name": "accepted run cannot receive conflicting result",
      "operation": "submit-result",
      "same_key": false,
      "same_fingerprint": false,
      "expected_disposition": "CONFLICT",
      "expected_code": "ACTION_PLAN_RESULT_IDEMPOTENCY_CONFLICT",
      "expected_terminal_transitions": 0
    }
  ],
  "authorizationDecisions": [
    {
      "name": "anonymous command fails closed",
      "operation": "request-execution",
      "authenticated": false,
      "owner_matches": false,
      "realm_matches": false,
      "expected_allowed": false,
      "expected_code": "ACTION_PLAN_EXECUTION_AUTH_REQUIRED"
    },
    {
      "name": "wrong authenticated owner cannot read run",
      "operation": "read-status",
      "authenticated": true,
      "owner_matches": false,
      "realm_matches": true,
      "expected_allowed": false,
      "expected_code": "ACTION_PLAN_EXECUTION_NOT_FOUND"
    },
    {
      "name": "cross-realm result is indistinguishable from missing run",
      "operation": "submit-result",
      "authenticated": true,
      "owner_matches": true,
      "realm_matches": false,
      "expected_allowed": false,
      "expected_code": "ACTION_PLAN_EXECUTION_NOT_FOUND"
    },
    {
      "name": "authenticated assigned executor may submit matching result",
      "operation": "submit-result",
      "authenticated": true,
      "owner_matches": true,
      "realm_matches": true,
      "expected_allowed": true,
      "expected_code": "ACTION_PLAN_EXECUTION_RESULT_ACCEPTED"
    }
  ],
  "zeroEffectContract": {
    "rejected_request_expected_effects": {
      "execution_callback": 0,
      "local_command": 0,
      "worker_job": 0,
      "new_run": 0,
      "sibling_result": 0,
      "plan_success": 0,
      "provider_call": 0,
      "success_acknowledgement": 0
    }
  }
}
